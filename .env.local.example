# Supabase Configuration
NEXT_PUBLIC_SUPABASE_URL=your_supabase_url
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_supabase_anon_key
# service_role secret (eyJ…) или новый Secret key (sb_secret_…) — обязателен для Pro после оплаты
SUPABASE_SERVICE_ROLE_KEY=your_supabase_service_role_key
# SUPABASE_SECRET_KEY=sb_secret_...

# App URL (для Stripe redirect после оплаты)
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Stripe — https://docs.stripe.com/keys
# Test keys: Dashboard → Developers → API keys (sandbox mode)
STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...
# Price ID подписки $10/мес: Products → создайте Product + recurring Price → скопируйте price_...
STRIPE_PRICE_ID=price_...

# Опционально: publishable key для будущих Stripe Elements
# NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_...
